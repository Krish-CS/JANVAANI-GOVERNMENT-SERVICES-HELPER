# ============================================================
# JanVaani Backend — Environment Variables
# Copy this file to .env and fill in your API keys
# API-based mode: cloud STT + LLM + TTS
# ============================================================

# --- Groq (LLM Primary) ---
# Signup: https://console.groq.com
# Free: rate-limited LLM
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Cerebras (LLM Backup) ---
# Signup: https://cloud.cerebras.ai
# Free: 1M tokens/day
CEREBRAS_API_KEY=your_cerebras_api_key_here

# --- NVIDIA NIM (LLM Backup) ---
# Signup: https://build.nvidia.com
# Free tier inference
NVIDIA_API_KEY=nvapi-your_nvidia_api_key_here

# --- Groq STT ---
# STT model options include whisper-large-v3-turbo
GROQ_STT_MODEL=whisper-large-v3-turbo

# --- Azure Speech (TTS Primary) ---
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=centralindia
AZURE_TTS_VOICE_EN=en-IN-NeerjaNeural
AZURE_TTS_VOICE_HI=hi-IN-SwaraNeural
AZURE_TTS_VOICE_TA=ta-IN-PallaviNeural
AZURE_TTS_OUTPUT_FORMAT=riff-24khz-16bit-mono-pcm

# --- Sarvam AI (TTS Primary) ---
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TTS_ENDPOINT=https://api.sarvam.ai/text-to-speech

# --- Bhashini (TTS Fallback) ---
BHASHINI_USER_ID=your_bhashini_user_id_here
BHASHINI_API_KEY=your_bhashini_api_key_here
BHASHINI_PIPELINE_ID=your_bhashini_pipeline_id_here
BHASHINI_TTS_ENDPOINT=https://dhruva-api.bhashini.gov.in/services/inference/pipeline

# --- App Config ---
# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=https://janvaani-navy.vercel.app
# PORT=8000
LOG_LEVEL=info

# --- LLM Runtime Tuning ---
# Recommended low-latency default model
GROQ_LLM_MODEL=openai/gpt-oss-120b
# Hard timeout per provider request in seconds
LLM_REQUEST_TIMEOUT_SECONDS=20
# Retry count per provider
LLM_MAX_RETRIES=1

# Max seconds to wait for TTS provider before returning text-only response
TTS_GENERATION_TIMEOUT_SECONDS=20
